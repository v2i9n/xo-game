import random

def print_board(board):
    print()
    for i in range(0, 9, 3):
        print(f" {board[i]} | {board[i+1]} | {board[i+2]} ")
        if i < 6: print("-----------")
    print()

def check_win(board, player):
    win_combos = [(0,1,2), (3,4,5), (6,7,8), (0,3,6), (1,4,7), (2,5,8), (0,4,8), (2,4,6)]
    return any(all(board[i] == player for i in combo) for combo in win_combos)

def xo_game():
    name = "Hussein"
    your_wins = 0
    computer_wins = 0

    print(f"🔥 أهلاً {name} في لعبة XO المطورة!")

    while True:
        board = [" "] * 9
        player_turn = True

        while True:
            print_board(board)

            if player_turn:
                try:
                    move = int(input(f"اختار رقم من 1-9: دورك يا {name}! ")) - 1
                    if move < 0 or move > 8 or board[move]!= " ":
                        print("❌ خانة غلط! اختار رقم فاضي من 1-9")
                        continue
                    board[move] = "X"
                except ValueError:
                    print("❌ لازم تدخل رقم بس!")
                    continue
            else:
                empty = [i for i, spot in enumerate(board) if spot == " "]
                move = random.choice(empty)
                board[move] = "O"
                print(f"الكمبيوتر لعب في الخانة {move + 1}")

            if check_win(board, "X"):
                print_board(board)
                print(f"🎉 مبروووك يا {name} أنت أسطورة! فزت على الكمبيوتر")
                your_wins += 1
                break
            elif check_win(board, "O"):
                print_board(board)
                print(f"💻 الكمبيوتر فاز! حظ أوفر يا {name}")
                computer_wins += 1
                break
            elif " " not in board:
                print_board(board)
                print("🤝 تعادل! لعبة قوية")
                break

            player_turn = not player_turn

        print(f"\n📊 النتيجة: أنت {your_wins} - {computer_wins} الكمبيوتر")
        again = input("تلعب مرة ثانية؟ اكتب 'نعم' أو أي شي ثاني للخروج: ")
        if again.lower()!= "نعم":
            print(f"\n🏆 النتيجة النهائية: {name} {your_wins} - {computer_wins} الكمبيوتر")
            if your_wins > computer_wins:
                print("🔥 أنت البطل! تفوقت على الكمبيوتر")
            elif computer_wins > your_wins:
                print("💻 الكمبيوتر فاز هالمرة. ارجع له!")
            else:
                print("🤝 تعادل في النتيجة النهائية!")
            print("شكراً للعب يا وحش 👋")
            break

xo_game()
